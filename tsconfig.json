      ],
      "@admc-addons-sbrf.tmpos/models-states.tmpos": [
        "libs/models-states.tmpos/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/models-states.cards": [
        "libs/models-states.cards/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/providers-states.tmpos": [
        "libs/providers-states.tmpos/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/providers-states.cards": [
        "libs/providers-states.cards/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/providers-events": [
        "libs/providers-events/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/providers-events.configuration": [
        "libs/providers-events.configuration/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/providers-events.commands": [
        "libs/providers-events.commands/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/providers-events.adm": [
        "libs/providers-events.adm/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/providers-events.routing": [
        "libs/providers-events.routing/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/providers-messages": [
