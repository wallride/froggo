      ],
      "@admc-addons-sbrf.tmpos/models-events.commands": [
        "libs/models-events.commands/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/models-events.cards": [
        "libs/models-events.cards/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/models-events.configuration": [
        "libs/models-events.configuration/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/components-message-processing": [
        "libs/components/message-processing/src/index.ts"
      ],
      "@admc-addons-sbrf.tmpos/monitoring": [
        "libs/monitoring/src/index.ts"
      ]
